# =============================================================
# .env.example — Copy to .env.local for local development
# In production: all values come from AWS Secrets Manager
# NEVER commit real values to git!
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:localpassword123@localhost:5432/financedb

# ── JWT (shared across all services) ─────────────────────────
# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET=local-dev-access-secret-min-32-chars-ok
JWT_REFRESH_SECRET=local-dev-refresh-secret-different-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:localredispass@localhost:6379

# ── AWS — LocalStack (no real AWS needed for local dev) ──────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
AWS_S3_BUCKET=finance-platform-uploads-dev
AWS_SQS_PROCESSING_URL=http://localhost:4566/000000000000/document-processing
AWS_S3_PRESIGNED_URL_EXPIRY=300
AWS_S3_MAX_FILE_SIZE=10485760

# ── AI (optional — chatbot and AI categorization) ─────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Service Ports ─────────────────────────────────────────────
# auth-service:         3001
# upload-service:       3002
# processing-service:   3003
# analytics-service:    3004
# notification-service: 3005
