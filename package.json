{
  "name": "finance-platform",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start:auth": "npx nx serve auth-service",
    "start:upload": "npx nx serve upload-service",
    "start:processing": "npx nx serve processing-service",
    "start:analytics": "npx nx serve analytics-service",
    "start:notification": "npx nx serve notification-service",
    "build:all": "nx run-many --target=build --all --prod",
    "test": "nx run-many --target=test --all --passWithNoTests",
    "test:auth": "npx nx test auth-service --passWithNoTests",
    "test:upload": "npx nx test upload-service --passWithNoTests",
    "lint": "nx run-many --target=lint --all",
    "prisma:generate": "prisma generate --schema=libs/database/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=libs/database/prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=libs/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=libs/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/client-sqs": "^3.995.0",
    "@aws-sdk/client-textract": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.1",
    "@prisma/client": "^5.10.0",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "redis": "^4.6.13",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@nx/eslint": "^22.5.2",
    "@nx/js": "^18.0.0",
    "@nx/nest": "^18.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nx": "^18.0.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
